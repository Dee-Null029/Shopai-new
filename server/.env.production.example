PORT=5000
NODE_ENV=production
TRUST_PROXY=true

# Replace with your Azure VM public IP/domain. Include every browser origin that can call the API.
# Examples:
# ALLOWED_ORIGINS=http://20.10.10.10,https://shopai.example.com
ALLOWED_ORIGINS=http://YOUR_AZURE_VM_PUBLIC_IP

# MongoDB local VM service
MONGODB_URI=mongodb://127.0.0.1:27017/shopai

# Redis local VM service
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=replace-with-private-openai-key

# Affiliate Keys
AMAZON_AFFILIATE_TAG=
FLIPKART_AFFILIATE_ID=
FLIPKART_AFFILIATE_TOKEN=
MYNTRA_AFFILIATE_ID=

# Scraping
PROXY_LIST=
MAX_CONCURRENT_SCRAPES=2
MAX_RESULTS_PER_PLATFORM=24
SCRAPE_TIMEOUT=30000
