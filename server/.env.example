PORT=5000
NODE_ENV=development
TRUST_PROXY=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/shopai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Affiliate Keys
AMAZON_AFFILIATE_TAG=your-amazon-tag-20
FLIPKART_AFFILIATE_ID=your-flipkart-affiliate-id
FLIPKART_AFFILIATE_TOKEN=your-flipkart-token
MYNTRA_AFFILIATE_ID=your-myntra-affiliate-id

# Scraping
PROXY_LIST=
MAX_CONCURRENT_SCRAPES=3
MAX_RESULTS_PER_PLATFORM=24
SCRAPE_TIMEOUT=30000
